# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=your-anon-key

# Anthropic — powers the live AI agent (server-side only, never expose to the client)
ANTHROPIC_API_KEY=
# Optional: override the model used by the agent (defaults to claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Twilio — notificación real de leads por WhatsApp/SMS (server-side).
# Sin estas variables, el sitio sigue funcionando: guarda el lead en Supabase
# y abre WhatsApp en el cliente; solo se omite el aviso automático al dueño.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número Twilio que envía los SMS (formato E.164):
TWILIO_SMS_FROM=
# Opcional: remitente de WhatsApp (sandbox o número aprobado). Si está, se
# prefiere WhatsApp sobre SMS para las notificaciones:
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# A dónde llegan los avisos de leads (tu número, E.164). Default: +525561800423
LEAD_NOTIFY_TO=

# A futuro, según integraciones reales:
# RESEND_API_KEY=
# STRIPE_SECRET_KEY=
# CALCOM_API_KEY=
# ELEVENLABS_API_KEY=
# CARTESIA_API_KEY=
